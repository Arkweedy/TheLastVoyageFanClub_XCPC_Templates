\PYG{+w}{    }\PYG{n}{plane}\PYG{p}{(}\PYG{n}{p3}\PYG{+w}{ }\PYG{n}{r}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{p3}\PYG{+w}{ }\PYG{n}{a}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{:}\PYG{+w}{ }\PYG{n}{nor}\PYG{p}{(}\PYG{n}{r}\PYG{p}{.}\PYG{n}{unit}\PYG{p}{()),}\PYG{+w}{ }\PYG{n}{m}\PYG{p}{(}\PYG{n}{dot}\PYG{p}{(}\PYG{n}{nor}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{a}\PYG{p}{))}\PYG{+w}{ }\PYG{p}{\PYGZob{}\PYGZcb{}}
