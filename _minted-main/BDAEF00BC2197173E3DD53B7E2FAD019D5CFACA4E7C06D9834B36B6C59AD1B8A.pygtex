\PYG{c+cm}{ * @return 点 a 在平面 b 上的正交投影点。}
\PYG{c+cm}{ */}
\PYG{n}{p3}\PYG{+w}{ }\PYG{n+nf}{project\PYGZus{}to\PYGZus{}plane}\PYG{p}{(}\PYG{n}{p3}\PYG{+w}{ }\PYG{n}{a}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{plane}\PYG{+w}{ }\PYG{n}{b}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{    }\PYG{c+c1}{// a 到平面的有向距离为 (dot(a, b.nor) \PYGZhy{} b.m)}
\PYG{+w}{    }\PYG{c+c1}{// 从 a 点沿着法向量反方向移动这段距离即可到达投影点}
\PYG{+w}{    }\PYG{k}{return}\PYG{+w}{ }\PYG{n}{a}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{b}\PYG{p}{.}\PYG{n}{nor}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{b}\PYG{p}{.}\PYG{n}{m}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{+w}{ }\PYG{n}{dot}\PYG{p}{(}\PYG{n}{a}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{b}\PYG{p}{.}\PYG{n}{nor}\PYG{p}{));}
